# ==========================================================
#  Aa Portal - Backend  (copia este archivo a .env y rellena)
# ==========================================================

# --- MySQL de Raiola -------------------------------------------------
# En local (Opción A): activa "Remote MySQL" en cPanel y mete tu IP.
#   DB_HOST = host/IP remoto que te da Raiola.
# En producción (dentro del hosting): normalmente DB_HOST=localhost.
DB_HOST=
DB_PORT=3306
DB_NAME=          # nombre de la BD creada en cPanel (suele llevar prefijo: usuario_portal)
DB_USER=          # usuario MySQL de cPanel (también con prefijo: usuario_xxx)
DB_PASSWORD=

# --- Autenticación ---------------------------------------------------
# JWT_SECRET: cadena larga y aleatoria. Genera una con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Solo se usan al ejecutar `npm run seed` para crear/actualizar tu usuario.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Servidor --------------------------------------------------------
PORT=3001
# Orígenes permitidos por CORS (separados por coma).
# En local el frontend Vite corre en 5173.
# En producción: https://portal.tudominio.com
CORS_ORIGIN=http://localhost:5173
